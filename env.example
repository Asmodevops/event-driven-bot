# --- Telegram ---
BOT_TOKEN=put-your-token-here

# --- Логи (общие для всех сервисов) ---
# Уровень: DEBUG | INFO | WARNING | ERROR.
LOG_LEVEL=INFO
# 1 — JSON-логи (для прода/сбора), 0 — человекочитаемый формат (для локалки).
LOG_JSON=1

# --- Инфраструктура (хосты совпадают с именами сервисов в docker-compose) ---
# Если запускаете сервис на хосте, а не в Docker — укажите localhost, например
# NATS_URL=nats://localhost:4222
NATS_URL=nats://nats:4222
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/postgres
REDIS_PASSWORD=redis
# Анти-флуд gateway: не чаще одного апдейта от пользователя за N секунд.
THROTTLE_TIME=0.5
# Пул соединений к Postgres (user_service).
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# --- Глобальный лимит sender: SENDER_RATE сообщений за SENDER_PER секунд ---
SENDER_RATE=30
SENDER_PER=1
# Pull-батч sender из JetStream: тянуть до N штук, ожидая не дольше T секунд.
SENDER_BATCH_SIZE=25
SENDER_BATCH_TIMEOUT=1.0
# Повторы при временных сбоях: всего попыток, затем — в DLQ.
SENDER_MAX_ATTEMPTS=5
# Экспоненциальный backoff: задержка = base * 2^(попытка-1), но не больше cap (сек).
SENDER_BACKOFF_BASE=2.0
SENDER_BACKOFF_CAP=60.0
